<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  <!-- 📦 Package -->
	  <PackageId>JsonTemplateCore</PackageId>
	  <Version>1.0.0</Version>
	  <Authors>Sebastián Garcia</Authors>
	  <Company>Sebastián Garcia</Company>
	  <Product>JsonTemplateCore</Product>

	  <!-- 🧾 Descripción -->
	  <Description>
		  Lightweight and fast JSON-based templating engine for .NET.
		  Supports nested properties, arrays, and flexible template syntax like $(Path.To.Value).
	  </Description>

	  <!-- 🔍 SEO NuGet -->
	  <PackageTags>json template templating engine interpolation jsonpath render</PackageTags>

	  <!-- 🌍 Links -->
	  <RepositoryUrl>https://github.com/tuusuario/JsonTemplateCore</RepositoryUrl>
	  <RepositoryType>git</RepositoryType>
	  <PackageProjectUrl>https://github.com/tuusuario/JsonTemplateCore</PackageProjectUrl>
	  <PackageLicenseExpression>MIT</PackageLicenseExpression>

	  <!-- 📄 Docs -->
	  <PackageReadmeFile>README.md</PackageReadmeFile>

	  <!-- 📦 Build -->
	  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  <IncludeSymbols>true</IncludeSymbols>
	  <SymbolPackageFormat>snupkg</SymbolPackageFormat>

	  <!-- ⚙️ Calidad -->
	  <Nullable>enable</Nullable>
	  <ImplicitUsings>enable</ImplicitUsings>
	  <LangVersion>latest</LangVersion>

	  <!-- 🔒 Deterministic builds -->
	  <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
	  <Deterministic>true</Deterministic>
  </PropertyGroup>
    
</Project>
